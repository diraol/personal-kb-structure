#!/usr/bin/env bash
# Health check for the kb vault stack.
# Usage: ./bin/kb-health
set -euo pipefail

REPO="$(cd "$(dirname "$(readlink -f "$0")")/.." && pwd)"
cd "$REPO"

# Resolve uv to the real binary (not a pyenv shim)
_resolve_uv() {
  local bin
  bin="$(command -v uv 2>/dev/null || true)"
  [[ -z "$bin" ]] && return 1
  if [[ "$bin" == *pyenv/shims/* ]]; then
    local root="${PYENV_ROOT:-$HOME/.pyenv}"
    bin="$(find "$root/versions" -name uv -type f 2>/dev/null | grep -v '/envs/' | sort -V | tail -1 || true)"
    [[ -z "$bin" ]] && bin="$(find "$root/versions" -name uv -type f 2>/dev/null | sort -V | tail -1 || true)"
  fi
  [[ -n "$bin" ]] && echo "$bin" || return 1
}
UV_BIN="$(_resolve_uv || true)"
if [[ -z "$UV_BIN" ]]; then
  echo "ERROR: uv not found" >&2; exit 1
fi

ok=0; fail=0
check() {
  local label="$1" status="$2" detail="${3:-}"
  if [[ "$status" == "ok" ]]; then
    printf '  ✓  %-30s %s\n' "$label" "$detail"
    (( ok++ )) || true
  else
    printf '  ✗  %-30s %s\n' "$label" "$detail" >&2
    (( fail++ )) || true
  fi
}

echo "━━━ watcher ━━━"
if systemctl --user is-active kb-watch.service >/dev/null 2>&1; then
  check "kb-watch.service" ok "$(systemctl --user show kb-watch.service --property=MainPID --value | xargs -I{} ps -p {} -o pid= -o etime= 2>/dev/null | head -1 || echo "")"
else
  check "kb-watch.service" fail "not running — systemctl --user start kb-watch"
fi

echo
echo "━━━ ollama / embeddings ━━━"
if command -v ollama >/dev/null 2>&1; then
  if ollama list 2>/dev/null | grep -q "nomic-embed-text"; then
    if "$UV_BIN" run --project "$REPO" python -c "from kb.embed import health; ok, _ = health(); exit(0 if ok else 1)" 2>/dev/null; then
      check "nomic-embed-text" ok "reachable"
    else
      check "nomic-embed-text (daemon)" fail "ollama is installed but not responding — is 'ollama serve' running?"
    fi
  else
    check "nomic-embed-text" fail "not pulled — run: ollama pull nomic-embed-text"
  fi
else
  check "ollama" fail "not installed — see https://ollama.com/install.sh"
fi

echo
echo "━━━ indexes ━━━"
"$UV_BIN" run --project "$REPO" python - <<'PYEOF'
import sqlite3, sys
from kb import vector
from kb.config import FTS_DB

try:
    con = sqlite3.connect(FTS_DB)
    notes  = con.execute("SELECT COUNT(*) FROM notes").fetchone()[0]
    chunks = con.execute("SELECT COUNT(*) FROM notes_fts").fetchone()[0]
    con.close()
    icon = "✓" if notes else "✗"
    print(f"  {icon}  {'FTS5':<30} {notes} notes, {chunks} chunks")
except Exception as e:
    print(f"  ✗  {'FTS5':<30} {e}", file=sys.stderr)

try:
    n = vector.table().count_rows()
    icon = "✓" if n else "✗"
    print(f"  {icon}  {'LanceDB':<30} {n} vectors")
except Exception as e:
    print(f"  ✗  {'LanceDB':<30} {e}", file=sys.stderr)
PYEOF

echo
echo "━━━ mcp server ━━━"
KB_MCP_PORT="${KB_MCP_PORT:-3333}"
if systemctl --user is-active kb-mcp-server.service >/dev/null 2>&1; then
  uptime="$(systemctl --user show kb-mcp-server.service --property=MainPID --value | \
    xargs -I{} ps -p {} -o etime= 2>/dev/null | head -1 | xargs || echo "")"
  check "kb-mcp-server.service" ok "up ${uptime}"
else
  check "kb-mcp-server.service" fail "not running — systemctl --user start kb-mcp-server"
fi
health_resp="$(curl -sf --max-time 3 "http://127.0.0.1:${KB_MCP_PORT}/health" 2>/dev/null || true)"
if [[ -n "$health_resp" ]]; then
  check "kb-server HTTP :${KB_MCP_PORT}" ok "$health_resp"
else
  check "kb-server HTTP :${KB_MCP_PORT}" fail "not responding — systemctl --user start kb-mcp-server"
fi

echo
echo "━━━ claude.json MCP config ━━━"
mcp_entry=$(python3 -c "
import json, os
path = os.path.expanduser('~/.claude.json')
try:
    d = json.load(open(path))
    kb = d.get('mcpServers', {}).get('kb', {})
    if kb.get('url'):
        print('http:', kb['url'])
    elif kb.get('command'):
        print('stdio:', kb['command'], *kb.get('args', []))
    else:
        print('')
except Exception as e:
    print('error:', e)
" 2>/dev/null)
if [[ "$mcp_entry" == "http: http://127.0.0.1:${KB_MCP_PORT}/mcp" ]]; then
  check "mcpServers.kb" ok "$mcp_entry"
elif [[ "$mcp_entry" == stdio:* ]]; then
  check "mcpServers.kb" ok "$mcp_entry  (stdio mode)"
else
  check "mcpServers.kb" fail "missing — run: ./claude-integration/install.sh"
fi

echo
echo "━━━ symlinks ━━━"
for entry in \
  "skill:kb-search:$HOME/.claude/skills/kb-search" \
  "skill:kb-capture:$HOME/.claude/skills/kb-capture" \
  "skill:kb-consolidate:$HOME/.claude/skills/kb-consolidate" \
  "hook:kb-session-context.sh:$HOME/.claude/hooks/kb-session-context.sh" \
  "hook:kb-stop-prompt.sh:$HOME/.claude/hooks/kb-stop-prompt.sh"; do
  IFS=: read -r kind name path <<< "$entry"
  if [[ -L "$path" && -e "$path" ]]; then
    check "$kind/$name" ok "→ $(readlink "$path")"
  else
    check "$kind/$name" fail "broken or missing — run: ./claude-integration/install.sh"
  fi
done

echo
echo "━━━ session hook ━━━"
output=$(CLAUDE_PROJECT_DIR="$REPO" bash "$REPO/claude-integration/hooks/kb-session-context.sh" 2>/dev/null | head -1)
if [[ "$output" == "<kb-project-context"* ]]; then
  check "SessionStart hook" ok "injects project context for $(basename "$REPO")"
else
  check "SessionStart hook" fail "no output — ensure vault/projects/$(basename "$REPO")/_index.md exists"
fi

echo
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
if (( fail == 0 )); then
  printf '  All %d checks passed.\n' "$ok"
else
  printf '  %d passed, %d failed.\n' "$ok" "$fail"
  exit 1
fi
