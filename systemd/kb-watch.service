[Unit]
Description=kb vault watcher — incremental reindex on save
Documentation=https://github.com/nubank/diraol-personal-kb
After=default.target

[Service]
Type=simple
WorkingDirectory=%h/kb
ExecStart=@UV_BIN@ run --project %h/kb kb-watch
Restart=on-failure
RestartSec=5s
StandardOutput=append:%h/kb/.logs/kb-watch.log
StandardError=append:%h/kb/.logs/kb-watch.log
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=default.target
